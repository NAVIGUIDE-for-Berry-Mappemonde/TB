Private Function ColonneExiste(lo As ListObject, n As String) As Boolean
    Dim lc As ListColumn: ColonneExiste = False
    For Each lc In lo.ListColumns
        If LCase(lc.Name) = LCase(n) Then ColonneExiste = True: Exit Function
    Next lc
End Function

Private Function GetColIndex(lo As ListObject, n As String) As Long
    Dim lc As ListColumn: GetColIndex = 0
    For Each lc In lo.ListColumns
        If LCase(lc.Name) = LCase(n) Then GetColIndex = lc.Index: Exit Function
    Next lc
End Function

Private Function TrouverLigneTable(lo As ListObject, idV As String) As Long
    TrouverLigneTable = 0
    If lo.DataBodyRange Is Nothing Then Exit Function
    Dim r As Long
    For r = 1 To lo.DataBodyRange.Rows.Count
        If Trim(CStr(lo.DataBodyRange.Cells(r, 1).Value)) = idV Then TrouverLigneTable = r: Exit Function
    Next r
End Function

Public Function ExtraireSIGMI(txt As String) As String
    ExtraireSIGMI = ""
    Dim p As Long: p = InStr(1, txt, "SI-GMI:", vbTextCompare)
    If p > 0 Then
        Dim s As String: s = Mid(txt, p + 7)
        s = Trim(Left(s, InStr(s & "|", "|") - 1))
        ExtraireSIGMI = Trim(Replace(s, "]", ""))
    End If
End Function

Public Function ExtraireNAM(txt As String) As String
    ExtraireNAM = ""
    Dim p As Long: p = InStr(1, txt, "NAM:", vbTextCompare)
    If p > 0 Then
        Dim s As String: s = Mid(txt, p + 4)
        s = Trim(Left(s, InStr(s & "]", "]") - 1))
        ExtraireNAM = Trim(Replace(s, "|", ""))
    End If
End Function

Public Function ExtraireChamp(txt As String, champ As String) As String
    ExtraireChamp = ""
    Dim p As Long: p = InStr(1, txt, champ & ":", vbTextCompare)
    If p > 0 Then
        Dim s As String: s = Mid(txt, p + Len(champ) + 1)
        Dim pP As Long, pL As Long, pE As Long
        pP = InStr(s, "|"): pL = InStr(s, vbLf)
        If pP = 0 Then pP = 9999
        If pL = 0 Then pL = 9999
        pE = pP: If pL < pE Then pE = pL
        If pE = 9999 Then pE = Len(s) + 1
        ExtraireChamp = Trim(Left(s, pE - 1))
    End If
End Function

Public Function CalculerAge(ddn As String) As String
    CalculerAge = ""
    On Error Resume Next
    If ddn = "" Then Exit Function
    Dim d As Date: d = CDate(ddn)
    If Err.Number <> 0 Then Exit Function
    Dim age As Long: age = DateDiff("yyyy", d, Date)
    If Date < DateSerial(Year(Date), Month(d), Day(d)) Then age = age - 1
    CalculerAge = CStr(age)
    On Error GoTo 0
End Function

Public Sub AjouterColonnesSiAbsentes()
    On Error Resume Next
    Dim lo As ListObject, c As Variant
    Dim cols As Variant: cols = Array(COL_SUIVI, COL_NOTES, COL_CHEMIN, "Adresse_Usager", "Telephone_Usager")
    Set lo = ThisWorkbook.Sheets(WS_CAS).ListObjects(TBL_CAS)
    If Not lo Is Nothing Then
        For Each c In cols
            If Not ColonneExiste(lo, CStr(c)) Then lo.ListColumns.Add: lo.ListColumns(lo.ListColumns.Count).Name = CStr(c)
        Next c
    End If
    Set lo = ThisWorkbook.Sheets(WS_CONT).ListObjects(TBL_CONT)
    If Not lo Is Nothing Then
        For Each c In cols
            If Not ColonneExiste(lo, CStr(c)) Then lo.ListColumns.Add: lo.ListColumns(lo.ListColumns.Count).Name = CStr(c)
        Next c
    End If
    On Error GoTo 0
End Sub

Public Sub InitialiserGestionSiAbsent()
