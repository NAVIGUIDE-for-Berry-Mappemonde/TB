Public Sub RafraichirListe()
    Dim wsG As Worksheet
    On Error Resume Next: Set wsG = ThisWorkbook.Sheets(WS_GESTION)
    If wsG Is Nothing Then Exit Sub
    On Error GoTo 0
    Application.ScreenUpdating = False
    Dim nms() As String, cnt As Long: cnt = 0
    Dim shp As Shape
    For Each shp In wsG.Shapes
        If Left(shp.Name, 5) = "btnS_" Or Left(shp.Name, 5) = "btnD_" Then
            cnt = cnt + 1: ReDim Preserve nms(1 To cnt): nms(cnt) = shp.Name
        End If
    Next shp
    Dim ii As Long
    For ii = 1 To cnt: wsG.Shapes(nms(ii)).Delete: Next ii

    Dim mx As Long: mx = 200
    Dim tTy() As String, tId() As String, tDtE() As String
    Dim tNm() As String, tPr() As String, tDN() As String
    Dim tSv() As String, tCm() As String
    ReDim tTy(1 To mx): ReDim tId(1 To mx): ReDim tDtE(1 To mx)
    ReDim tNm(1 To mx): ReDim tPr(1 To mx): ReDim tDN(1 To mx)
    ReDim tSv(1 To mx): ReDim tCm(1 To mx)
    Dim n As Long: n = 0

    Dim loCas As ListObject
    Set loCas = ThisWorkbook.Sheets(WS_CAS).ListObjects(TBL_CAS)
    If Not loCas.DataBodyRange Is Nothing Then
        Dim cS As Long: cS = GetColIndex(loCas, COL_SUIVI)
        Dim r As Long
        For r = 1 To loCas.DataBodyRange.Rows.Count
            Dim iC As String: iC = Trim(CStr(loCas.DataBodyRange.Cells(r, 1).Value))
            If iC <> "" And iC <> "Exemple" Then
                n = n + 1
                tTy(n) = "CAS": tId(n) = iC
                tDtE(n) = Trim(CStr(loCas.DataBodyRange.Cells(r, 5).Value))
                tNm(n) = Trim(CStr(loCas.DataBodyRange.Cells(r, 6).Value))
                tPr(n) = Trim(CStr(loCas.DataBodyRange.Cells(r, 7).Value))
                tDN(n) = Trim(CStr(loCas.DataBodyRange.Cells(r, 8).Value))
                tCm(n) = Trim(CStr(loCas.DataBodyRange.Cells(r, 21).Value))
                If cS > 0 Then tSv(n) = Trim(CStr(loCas.DataBodyRange.Cells(r, cS).Value)) Else tSv(n) = ""
            End If
        Next r
    End If

    Dim loCo As ListObject
    Set loCo = ThisWorkbook.Sheets(WS_CONT).ListObjects(TBL_CONT)
    If Not loCo.DataBodyRange Is Nothing Then
        Dim cSo As Long: cSo = GetColIndex(loCo, COL_SUIVI)
        Dim cCm As Long: cCm = GetColIndex(loCo, "Commentaires")
        For r = 1 To loCo.DataBodyRange.Rows.Count
            Dim iCo As String: iCo = Trim(CStr(loCo.DataBodyRange.Cells(r, 1).Value))
            If iCo <> "" And iCo <> "Exemple" Then
                n = n + 1
                tTy(n) = "CONTACT": tId(n) = iCo
                tDtE(n) = Trim(CStr(loCo.DataBodyRange.Cells(r, 3).Value))
                tNm(n) = Trim(CStr(loCo.DataBodyRange.Cells(r, 6).Value))
                tPr(n) = Trim(CStr(loCo.DataBodyRange.Cells(r, 7).Value))
                tDN(n) = Trim(CStr(loCo.DataBodyRange.Cells(r, 8).Value))
                If cCm > 0 Then tCm(n) = Trim(CStr(loCo.DataBodyRange.Cells(r, cCm).Value)) Else tCm(n) = ""
                If cSo > 0 Then tSv(n) = Trim(CStr(loCo.DataBodyRange.Cells(r, cSo).Value)) Else tSv(n) = ""
            End If
        Next r
    End If
    If n = 0 Then Application.ScreenUpdating = True: Exit Sub

    Dim i As Long, j As Long, tmp As String
    For i = 1 To n - 1
        For j = i + 1 To n
            If tDtE(i) < tDtE(j) Then
                tmp = tTy(i): tTy(i) = tTy(j): tTy(j) = tmp
                tmp = tId(i): tId(i) = tId(j): tId(j) = tmp
                tmp = tDtE(i): tDtE(i) = tDtE(j): tDtE(j) = tmp
                tmp = tNm(i): tNm(i) = tNm(j): tNm(j) = tmp
                tmp = tPr(i): tPr(i) = tPr(j): tPr(j) = tmp
                tmp = tDN(i): tDN(i) = tDN(j): tDN(j) = tmp
                tmp = tSv(i): tSv(i) = tSv(j): tSv(j) = tmp
                tmp = tCm(i): tCm(i) = tCm(j): tCm(j) = tmp
            End If
        Next j
    Next i

    Dim mxR As Long: mxR = n
    Dim rw As Long, sg As String
    For i = 1 To mxR
        rw = i
        If rw > 19 Then wsG.Rows(rw).RowHeight = 20
        sg = ExtraireSIGMI(tCm(i))
        If sg = "" Then sg = tId(i)
        Dim bS As Shape
        Set bS = wsG.Shapes.AddShape(msoShapeRoundedRectangle, _
            wsG.Cells(rw, 1).Left + 1, wsG.Cells(rw, 1).Top + 2, 14, 14)
        bS.Name = "btnS_" & tId(i) & "_" & tTy(i)
        If UCase(tSv(i)) = "OUI" Then bS.Fill.ForeColor.RGB = RGB(0, 180, 0) Else bS.Fill.ForeColor.RGB = RGB(180, 180, 180)
        bS.TextFrame2.TextRange.Text = ""
        bS.Line.Visible = msoFalse
        bS.OnAction = "ToggleSuivi"
        Dim bD As Shape
        Set bD = wsG.Shapes.AddShape(msoShapeRoundedRectangle, _
            wsG.Cells(rw, 2).Left, wsG.Cells(rw, 2).Top, wsG.Cells(rw, 2).Width, 19)
        bD.Name = "btnD_" & tId(i) & "_" & tTy(i)
        If tTy(i) = "CAS" Then bD.Fill.ForeColor.RGB = RGB(220, 235, 250) Else bD.Fill.ForeColor.RGB = RGB(220, 245, 220)
        bD.Line.ForeColor.RGB = RGB(180, 180, 180)
        bD.TextFrame2.TextRange.Text = tNm(i) & ", " & tPr(i)
        bD.TextFrame2.TextRange.Font.Size = 8
        bD.TextFrame2.TextRange.Font.Fill.ForeColor.RGB = RGB(30, 30, 30)
        bD.TextFrame2.TextRange.ParagraphFormat.Alignment = msoAlignLeft
        bD.TextFrame2.MarginLeft = 4
        bD.OnAction = "CliquerDossier"
    Next i
    Application.ScreenUpdating = True
End Sub

Public Sub CliquerDossier()
    Dim nm As String: nm = Application.Caller
    Dim pts() As String: pts = Split(nm, "_")
    If UBound(pts) < 2 Then Exit Sub
    Dim typeV As String: typeV = pts(UBound(pts))
    Dim idV As String: idV = pts(1)
    Dim pp As Long
    For pp = 2 To UBound(pts) - 1
        idV = idV & "_" & pts(pp)
    Next pp
    mIdSel = idV: mTypeSel = typeV
    Dim wsG As Worksheet: Set wsG = ThisWorkbook.Sheets(WS_GESTION)
    Dim lo As ListObject
    If typeV = "CAS" Then Set lo = ThisWorkbook.Sheets(WS_CAS).ListObjects(TBL_CAS) Else Set lo = ThisWorkbook.Sheets(WS_CONT).ListObjects(TBL_CONT)
    Dim tR As Long: tR = TrouverLigneTable(lo, idV)
    mRowSel = tR: If tR = 0 Then Exit Sub
    Dim cCh As Long: cCh = GetColIndex(lo, COL_CHEMIN)
    If cCh > 0 Then wsG.Range("D1").Value = CStr(lo.DataBodyRange.Cells(tR, cCh).Value)
    RemplirResume lo, tR, wsG
    AfficherNotes idV, typeV, wsG
    Dim shp As Shape
    For Each shp In wsG.Shapes
        If Left(shp.Name, 5) = "btnD_" Then
            If shp.Name = nm Then shp.Fill.ForeColor.RGB = RGB(173, 216, 230) Else _
                If InStr(shp.Name, "_CAS") > 0 Then shp.Fill.ForeColor.RGB = RGB(220, 235, 250) Else shp.Fill.ForeColor.RGB = RGB(220, 245, 220)
        End If
    Next shp
End Sub

Public Sub ToggleSuivi()
    Dim nm As String: nm = Application.Caller
    Dim pts() As String: pts = Split(nm, "_")
    If UBound(pts) < 2 Then Exit Sub
    Dim typeV As String: typeV = pts(UBound(pts))
    Dim idV As String: idV = pts(1)
    Dim pp As Long
    For pp = 2 To UBound(pts) - 1
        idV = idV & "_" & pts(pp)
    Next pp
    Dim lo As ListObject
    If typeV = "CAS" Then Set lo = ThisWorkbook.Sheets(WS_CAS).ListObjects(TBL_CAS) Else Set lo = ThisWorkbook.Sheets(WS_CONT).ListObjects(TBL_CONT)
    Dim tR As Long: tR = TrouverLigneTable(lo, idV)
    If tR = 0 Then Exit Sub
    Dim cSv As Long: cSv = GetColIndex(lo, COL_SUIVI)
    If cSv = 0 Then Exit Sub
    Dim wsG As Worksheet: Set wsG = ThisWorkbook.Sheets(WS_GESTION)
    Dim act As String: act = UCase(Trim(CStr(lo.DataBodyRange.Cells(tR, cSv).Value)))
    If act = "OUI" Then
        lo.DataBodyRange.Cells(tR, cSv).Value = ""
        wsG.Shapes(nm).Fill.ForeColor.RGB = RGB(180, 180, 180)
    Else
        lo.DataBodyRange.Cells(tR, cSv).Value = "Oui"
        wsG.Shapes(nm).Fill.ForeColor.RGB = RGB(0, 180, 0)
    End If
End Sub

Private Sub RemplirResume(lo As ListObject, tR As Long, wsG As Worksheet)
    Dim nm As String, pr As String, dn As String, sx As String
    Dim st As String, si As String, md As String, cm As String
    If mTypeSel = "CAS" Then
        nm = CStr(lo.DataBodyRange.Cells(tR, 6).Value): pr = CStr(lo.DataBodyRange.Cells(tR, 7).Value)
        dn = CStr(lo.DataBodyRange.Cells(tR, 8).Value): sx = CStr(lo.DataBodyRange.Cells(tR, 9).Value)
        st = CStr(lo.DataBodyRange.Cells(tR, 4).Value): si = CStr(lo.DataBodyRange.Cells(tR, 10).Value)
        md = CStr(lo.DataBodyRange.Cells(tR, 17).Value): cm = CStr(lo.DataBodyRange.Cells(tR, 21).Value)
    Else
        nm = CStr(lo.DataBodyRange.Cells(tR, 6).Value): pr = CStr(lo.DataBodyRange.Cells(tR, 7).Value)
        dn = CStr(lo.DataBodyRange.Cells(tR, 8).Value): sx = CStr(lo.DataBodyRange.Cells(tR, 9).Value)
        st = CStr(lo.DataBodyRange.Cells(tR, 5).Value): si = ""
        md = CStr(lo.DataBodyRange.Cells(tR, 22).Value)
        Dim cCm2 As Long: cCm2 = GetColIndex(lo, "Commentaires")
        If cCm2 > 0 Then cm = CStr(lo.DataBodyRange.Cells(tR, cCm2).Value)
    End If
    Dim gmi As String, ram As String, py As String, ar As String
    Dim med As String, res As String, adr As String, tel As String
    gmi = ExtraireSIGMI(cm): If gmi = "" Then gmi = mIdSel
    ram = ExtraireNAM(cm)
    py = ExtraireChamp(cm, "Pays"): ar = ExtraireChamp(cm, "Arriv")
    med = ExtraireChamp(cm, "dication"): res = ExtraireChamp(cm, "SISTANCE")
    ' v9: Lire adresse et telephone depuis les colonnes dediees
    Dim cAdr As Long: cAdr = GetColIndex(lo, "Adresse_Usager")
    Dim cTel As Long: cTel = GetColIndex(lo, "Telephone_Usager")
    If cAdr > 0 Then adr = CStr(lo.DataBodyRange.Cells(tR, cAdr).Value) Else adr = ""
    If cTel > 0 Then tel = CStr(lo.DataBodyRange.Cells(tR, cTel).Value) Else tel = ""
    ' Fallback: si colonnes vides, essayer les commentaires
    If adr = "" Then adr = ExtraireChamp(cm, "Adresse")
    If tel = "" Then tel = ExtraireChamp(cm, "phone")
    wsG.Range("D2:L2").ClearContents
    wsG.Range("D3:L3").ClearContents
    wsG.Range("D4:L4").ClearContents
    wsG.Range("D5:L5").ClearContents
    wsG.Range("D6:L6").ClearContents
    wsG.Range("D7:L7").ClearContents
    wsG.Range("D8:L8").ClearContents
    wsG.Range("D9:L9").ClearContents
    wsG.Range("D10:L10").ClearContents
    wsG.Range("D11:L11").ClearContents
    wsG.Range("D2").Value = gmi: wsG.Range("D2").Font.Italic = False
    wsG.Range("D3").Value = ram: wsG.Range("D4").Value = nm: wsG.Range("D5").Value = pr
    wsG.Range("D6").Value = dn & " | " & CalculerAge(dn) & " ans | " & sx
    wsG.Range("D7").Value = st
    wsG.Range("D7").Font.Bold = True: wsG.Range("D7").Font.Color = RGB(139, 0, 0)
    wsG.Range("D8").Value = si & " | " & md
    wsG.Range("D9").Value = py & " | " & ar
    wsG.Range("D10").Value = med
    If res <> "" Then
        wsG.Range("D11").Value = "!! " & res
        wsG.Range("D11").Font.Color = vbRed: wsG.Range("D11").Font.Bold = True
    Else
        wsG.Range("D11").Value = "Aucune"
    End If
    wsG.Range("N2").Value = nm: wsG.Range("N3").Value = pr
    wsG.Range("N4").Value = CalculerAge(dn): wsG.Range("N5").Value = dn
    wsG.Range("N6").Value = ram: wsG.Range("N7").Value = gmi
    wsG.Range("N8").Value = adr: wsG.Range("N9").Value = tel
End Sub

Public Sub AjouterNote()
    Dim wsG As Worksheet: Set wsG = ThisWorkbook.Sheets(WS_GESTION)
    If mIdSel = "" Then MsgBox "Selectionnez un dossier.", vbExclamation: Exit Sub
    Dim ct As String: ct = Trim(CStr(wsG.Range("D12").Value))
    If ct = "" Then MsgBox "Saisissez du texte dans la zone Note.", vbExclamation: Exit Sub
    Dim hd As String: hd = Format(Now, "yyyy-mm-dd hh:nn")
    Dim nc As String: nc = "[" & hd & " | " & Application.UserName & "] " & ct
    Dim lo As ListObject
    If mTypeSel = "CAS" Then Set lo = ThisWorkbook.Sheets(WS_CAS).ListObjects(TBL_CAS) Else Set lo = ThisWorkbook.Sheets(WS_CONT).ListObjects(TBL_CONT)
    Dim tR As Long: tR = TrouverLigneTable(lo, mIdSel)
    If tR > 0 Then
        Dim cN As Long: cN = GetColIndex(lo, COL_NOTES)
        If cN > 0 Then
            Dim ex As String: ex = CStr(lo.DataBodyRange.Cells(tR, cN).Value)
            If ex <> "" Then lo.DataBodyRange.Cells(tR, cN).Value = ex & vbLf & nc Else lo.DataBodyRange.Cells(tR, cN).Value = nc
        End If
    End If
    wsG.Range("D12").Value = ""
    AfficherNotes mIdSel, mTypeSel, wsG
End Sub

Public Sub AfficherNotes(idV As String, typeV As String, wsG As Worksheet)
    wsG.Range("C14:L19").ClearContents
    wsG.Range("C14:L19").Interior.ColorIndex = xlNone
    wsG.Range("C14:L19").MergeCells = False
    Dim lo As ListObject
    If typeV = "CAS" Then Set lo = ThisWorkbook.Sheets(WS_CAS).ListObjects(TBL_CAS) Else Set lo = ThisWorkbook.Sheets(WS_CONT).ListObjects(TBL_CONT)
    Dim tR As Long: tR = TrouverLigneTable(lo, idV)
    If tR = 0 Then Exit Sub
    Dim cN As Long: cN = GetColIndex(lo, COL_NOTES)
    If cN = 0 Then Exit Sub
    Dim an As String: an = CStr(lo.DataBodyRange.Cells(tR, cN).Value)
    If Trim(an) = "" Then wsG.Range("C14").Value = "(Aucune note)": wsG.Range("C14").Font.Italic = True: Exit Sub
    Dim na() As String: na = Split(an, vbLf)
    Dim rw As Long: rw = 14
    Dim ix As Long
    For ix = UBound(na) To 0 Step -1
        If rw > 19 Then Exit For
        If Trim(na(ix)) <> "" Then
            wsG.Range(wsG.Cells(rw, 3), wsG.Cells(rw, 12)).Merge
            wsG.Cells(rw, 3).Value = na(ix)
            wsG.Cells(rw, 3).WrapText = True: wsG.Cells(rw, 3).Font.Size = 7
            If (ix Mod 2) = 0 Then
                wsG.Range(wsG.Cells(rw, 3), wsG.Cells(rw, 12)).Interior.Color = RGB(220, 235, 250)
            Else
                wsG.Range(wsG.Cells(rw, 3), wsG.Cells(rw, 12)).Interior.Color = RGB(240, 240, 240)
            End If
            wsG.Range(wsG.Cells(rw, 3), wsG.Cells(rw, 12)).Borders.LineStyle = xlContinuous
            rw = rw + 1
        End If
    Next ix
End Sub

