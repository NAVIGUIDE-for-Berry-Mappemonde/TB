Public Sub GenererNoteWord()
    If mIdSel = "" Then MsgBox "Selectionnez un dossier.", vbExclamation: Exit Sub
    Dim wsG As Worksheet: Set wsG = ThisWorkbook.Sheets(WS_GESTION)
    Dim chM As String: chM = Trim(CStr(wsG.Range("N10").Value))
    If chM = "" Or Dir(chM) = "" Then chM = ThisWorkbook.Path & "\nom_prenom_notes_vierge.docx"
    If Dir(chM) = "" Then MsgBox "Modele introuvable: " & chM, vbExclamation: Exit Sub
    Dim nV As String: nV = CStr(wsG.Range("N2").Value)
    Dim pV As String: pV = CStr(wsG.Range("N3").Value)
    Dim aV As String: aV = CStr(wsG.Range("N4").Value)
    Dim dV As String: dV = CStr(wsG.Range("N5").Value)
    Dim rV As String: rV = CStr(wsG.Range("N6").Value)
    Dim sV As String: sV = CStr(wsG.Range("N7").Value)
    Dim adV As String: adV = CStr(wsG.Range("N8").Value)
    Dim tV As String: tV = CStr(wsG.Range("N9").Value)
    Dim lo As ListObject
    If mTypeSel = "CAS" Then Set lo = ThisWorkbook.Sheets(WS_CAS).ListObjects(TBL_CAS) Else Set lo = ThisWorkbook.Sheets(WS_CONT).ListObjects(TBL_CONT)
    Dim tR As Long: tR = TrouverLigneTable(lo, mIdSel)
    Dim ntV As String: ntV = ""
    If tR > 0 Then
        Dim cN As Long: cN = GetColIndex(lo, COL_NOTES)
        If cN > 0 Then ntV = CStr(lo.DataBodyRange.Cells(tR, cN).Value)
    End If
    Dim wA As Object, wD As Object
    On Error Resume Next
    Set wA = GetObject(, "Word.Application")
    If wA Is Nothing Then Set wA = CreateObject("Word.Application")
    On Error GoTo 0
    Set wD = wA.Documents.Open(chM)
    On Error Resume Next
    wD.Unprotect ""
    On Error GoTo 0

    ' Remplir les Content Controls par leur titre
    Dim oCC As Object
    For Each oCC In wD.ContentControls
        Select Case oCC.Title
            Case "Nom usager": oCC.Range.Text = nV
            Case "Prénom usager": oCC.Range.Text = pV
            Case "Âge usager": oCC.Range.Text = aV
            Case "DDN usager": oCC.Range.Text = dV
            Case "RAMQ usager": oCC.Range.Text = rV
            Case "ID USAGER": oCC.Range.Text = sV
            Case "ID SI-GMI": oCC.Range.Text = sV
            Case "Adresse usager": oCC.Range.Text = adV
            Case "Domicile usager": oCC.Range.Text = tV
            Case "Cellulaire usager": oCC.Range.Text = ""
            Case "Courriel usager": oCC.Range.Text = ""
            Case "Nom répondant": oCC.Range.Text = ""
            Case "Prénom répondant": oCC.Range.Text = ""
            Case "Lien avec l'usager": oCC.Range.Text = ""
            Case "Domicile répondant": oCC.Range.Text = ""
            Case "Cellulaire répondant": oCC.Range.Text = ""
            Case "Courriel répondant": oCC.Range.Text = ""
        End Select
    Next oCC

    If ntV <> "" Then
        On Error Resume Next
        Dim lastR As Long: lastR = wD.Tables(1).Rows.Count
        wD.Tables(1).Cell(lastR, 1).Range.Text = ntV
        On Error GoTo 0
    End If

    With wD.Content.Find
        .Text = "AAAA-MM-JJ"
        .Replacement.Text = Format(Date, "yyyy-mm-dd")
        .Execute Replace:=2
    End With
    Dim chD As String: chD = Trim(CStr(wsG.Range("D1").Value))
    If chD = "" Then chD = ThisWorkbook.Path & "\"
    If Right(chD, 1) <> "\" Then chD = chD & "\"
    On Error Resume Next: MkDir chD: On Error GoTo 0
    Dim nF As String: nF = UCase(nV) & "_" & pV & "_Notes_" & Format(Date, "yyyy-mm-dd") & ".docx"
    Dim chC As String: chC = chD & nF
    wD.SaveAs2 chC
    wA.Visible = True
    MsgBox "Note Word generee: " & vbCrLf & chC, vbInformation
End Sub

